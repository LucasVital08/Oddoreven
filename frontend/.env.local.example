# Address printed by `npx hardhat run scripts/deploy.ts --network local`.
# On a fresh Hardhat node the factory is usually the first deploy:
NEXT_PUBLIC_FACTORY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Optional: WalletConnect project id (free at https://cloud.reown.com).
# Injected wallets like MetaMask work without it.
NEXT_PUBLIC_WC_PROJECT_ID=
